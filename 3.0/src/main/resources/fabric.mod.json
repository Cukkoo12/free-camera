{
    "schemaVersion": 1,
    "id": "free-camera",
    "version": "${version}",
    "name": "Free Camera",
    "description": "A client-side camera mod with Free, Orbit, Tripod, Follow, recording, and path tools.",
    "authors": ["Cukkoo"],
    "contact": {
        "homepage": "https://github.com/Cukkoo12/free-camera",
        "sources": "https://github.com/Cukkoo12/free-camera",
        "issues": "https://github.com/Cukkoo12/free-camera/issues"
    },
    "license": "MIT",
    "icon": "assets/free-camera/icon.png",
    "environment": "client",
    "entrypoints": {
        "client": [
            "com.cukkoo.freecamera.FreeCameraClient"
        ],
        "modmenu": [
            "com.cukkoo.freecamera.integration.FreeCameraModMenuIntegration"
        ]
    },
    "mixins": [
        {
            "config": "free-camera.mixins.json",
            "environment": "client"
        }
    ],
    "depends": {
        "fabricloader": ">=0.18.5",
        "minecraft": "26.1.2",
        "java": ">=25",
        "fabric-api": ">=0.145.4+26.1.2"
    },
    "custom": {
        "loom:java_version": 25
    }
}
